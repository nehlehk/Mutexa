    "# add continent labels on a secondary y axis\n",
    "ax2 = axes[1].twinx()\n",
    "ax2.set_ylim(axes[1].get_ylim())\n",
    "ax2.set_yticks([])\n",
    "\n",
    "# Add secondary axis\n",
    "for cont, rows in continent_groups.items():\n",
    "    mid = (min(rows) + max(rows) + 1) / 2\n",
